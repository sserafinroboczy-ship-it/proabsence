# ProAbsence v1.0.0 - Konfiguracja środowiskowa
# Skopiuj ten plik jako .env i uzupełnij wartości

# Port aplikacji (domyślnie 3000)
PORT=3000

# Sekretny klucz JWT - WYMAGANY! Wygeneruj własny:
# openssl rand -base64 32
JWT_SECRET=ZMIEN_NA_WLASNY_KLUCZ_MIN_32_ZNAKI

# Środowisko
NODE_ENV=production
